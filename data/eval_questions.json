  "metrics": {
    "tool_selection_accuracy": {
      "description": "Agent 调用的工具集合是否包含期望工具（至少一个）",
      "formula": "TP / total"
    },
    "task_completion_rate": {
      "description": "最终答案是否包含至少一个期望关键词",
      "formula": "部分匹配 / total"
    },
    "tool_efficiency": {
      "description": "实际工具调用次数 / 最小所需调用次数（越低越好）",
      "formula": "avg(actual/min)"
    }
  }
